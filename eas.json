
{
  "cli": { "version": ">=18.0.0" },
  "build": {
    "internal": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": false }
    },
    "production": {
      "distribution": "store"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascApiKeyPath": "./AuthKey.p8",          
        "ascApiKeyIssuerId": "YOUR_ISSUER_ID",  
        "ascApiKeyId": "YOUR_KEY_ID"           
      }
    }
  }
}
